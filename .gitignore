# dependencies
node_modules/
scaffold/node_modules/
server/node_modules/

# build output
dist/
scaffold/dist/

# build-time copies of the component + lib/ + components/ (Dockerfile + npm run build replicate this)
scaffold/src/StatusTracker.jsx
scaffold/src/lib/
scaffold/src/components/

# SQLite database / WAL artifacts (only created locally if you run server outside docker)
*.db
*.db-journal
*.db-wal
*.db-shm

# vite cache
.vite/
scaffold/.vite/

# env files (never commit)
.env
.env.local
.env.*.local

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# editor / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# test / coverage
coverage/
.nyc_output/

# playwright session artifacts (created by the MCP browser tool)
.playwright-mcp/

# local backups (point scripts/backup.sh at a separate location)
backups/

# caveman:compress backups of memory files
*.original.md
