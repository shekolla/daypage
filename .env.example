# Copy this file to `.env` (already gitignored) and fill in real values.
# `docker compose up -d` (or `--build`) picks these up at runtime.

# ---- bootstrap admin --------------------------------------------------
# On first start, if the users table is empty AND both vars are set,
# this user is created with the given password. After the first user
# exists these are ignored. Manage further users via the CLI:
#
#   docker compose exec -it tracker node scripts/users.js create <name>
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASS=changeme

# ---- session signing key ---------------------------------------------
# Used to sign the auth cookie. Optional — if unset, a random secret is
# generated on first start and persisted in the SQLite `kv` table so
# sessions survive container restarts. Set this only if you want
# multi-replica or to rotate manually.
SESSION_SECRET=

# ---- cookie security -------------------------------------------------
# Set to "true" when serving over HTTPS so the auth cookie is sent only
# on TLS connections. Defaults to true in NODE_ENV=production. Set to
# "false" if you are running behind plain HTTP for testing on localhost.
COOKIE_SECURE=false

# ---- reverse proxy trust ---------------------------------------------
# How many trusted proxies sit between the public Internet and this
# container. 0 = no proxy (default; the server reads the actual TCP
# socket address for rate limiting). 1 = behind one TLS-terminating
# proxy like Caddy or nginx. 2 = behind a CDN (e.g. Cloudflare) that
# already sits in front of your nginx. Misconfiguring this exposes
# the per-IP login rate-limiter to header-spoofing — set it to match
# your real deployment topology.
TRUST_PROXY_HOPS=0

# ---- timezone --------------------------------------------------------
# Sets the container's local time. Affects server cron (due-date Chat
# pings), auto-post hour, and log timestamps. Each team can override
# this for their own due-date math via Settings → Timezone, but the env
# var is the sensible default for the unset case.
TZ=Asia/Kolkata
